# --- Environment ---
ENV=production
DEBUG=False
SECRET_KEY=replace-with-strong-secret

# --- Hosts ---
ALLOWED_HOSTS=quicksurf.onrender.com
CSRF_TRUSTED_ORIGINS=https://quicksurf.onrender.com
CORS_ALLOWED_ORIGINS=https://quicksurf.onrender.com
CORS_ALLOW_ALL_ORIGINS=False

# --- Infrastructure ---
DB_SSL_REQUIRE=True
REDIS_URL=rediss://default:password@host:6379
SECURE_HSTS_PRELOAD=True

# --- Providers ---
PROVIDER_MODE=LIVE
VTPASS_BASE_URL=https://vtpass.com/api
VTPASS_EMAIL=
VTPASS_API_KEY=
VTPASS_PUBLIC_KEY=
VTPASS_SECRET_KEY=
VTPASS_IP_WHITELISTED=True
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=

# --- App ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@quicksurf.app
DRF_USER_THROTTLE=1000/day
DRF_ANON_THROTTLE=100/day
JWT_REFRESH_DAYS=1
POINTS_PER_NAIRA=0.01
REWARDS_ENABLED=True
RECEIPT_EMAILS_ENABLED=True
